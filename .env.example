# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# NEVER expose this key to client application builds.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# SUPABASE_URL: The unique endpoint URL for your Supabase database instance.
# Retrieve from: Supabase Console -> Project Settings -> API
SUPABASE_URL=

# SUPABASE_ANON_KEY: The public anonymous API key for authenticating requests.
# Retrieve from: Supabase Console -> Project Settings -> API (anon public filter)
SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY: The secret elevated privileges bypass bypass API key.
# IMPORTANT: Keep this strictly backend-side; never publish this inside client scripts.
SUPABASE_SERVICE_ROLE_KEY=

# SMTP configuration for real-time automatic background order receipts.
# Define these in your Secrets tab to automatically email tamatamnarayana9@gmail.com on every order.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
